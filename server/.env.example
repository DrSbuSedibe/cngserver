# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cng_survey?retryWrites=true&w=majority

# Production email provider for Render
# Render is timing out on direct Gmail SMTP ports 465 and 587, so production should use HTTPS email API delivery.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="CNG Customer Satisfaction Survey <survey@your-verified-domain.com>"
RECEIVER_EMAILS=sedibesibusiso5@gmail.com,email2@gmail.com
RESEND_TIMEOUT_MS=20000
RESEND_RETRY_ATTEMPTS=3

# Optional Gmail SMTP fallback for local development or hosts where SMTP is reachable.
# EMAIL_PROVIDER=smtp
# EMAIL_USER=YOUR_GMAIL@gmail.com
# EMAIL_PASS=YOUR_16_CHARACTER_GOOGLE_APP_PASSWORD
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_RETRY_ATTEMPTS=3
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_GREETING_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=30000

# Backward-compatible legacy Gmail names also supported by the code:
# SMTP_EMAIL=YOUR_GMAIL@gmail.com
# SMTP_APP_PASSWORD=YOUR_16_CHARACTER_GOOGLE_APP_PASSWORD
# RECEIVER_EMAIL=recipient@example.com

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
