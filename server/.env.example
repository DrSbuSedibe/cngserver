# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cng_survey?retryWrites=true&w=majority

# Gmail SMTP Configuration
# EMAIL_PASS must be a 16-character Google App Password, not your normal Gmail password.
# Generate it at https://myaccount.google.com/apppasswords with 2-Step Verification enabled.
EMAIL_USER=YOUR_GMAIL@gmail.com
EMAIL_PASS=YOUR_16_CHARACTER_GOOGLE_APP_PASSWORD
RECEIVER_EMAILS=sedibesibusiso5@gmail.com,email2@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_RETRY_ATTEMPTS=3
SMTP_CONNECTION_TIMEOUT_MS=20000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=30000

# Backward-compatible legacy names also supported by the code:
# SMTP_EMAIL=YOUR_GMAIL@gmail.com
# SMTP_APP_PASSWORD=YOUR_16_CHARACTER_GOOGLE_APP_PASSWORD
# RECEIVER_EMAIL=recipient@example.com

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
